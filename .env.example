# Copy this file to .env and fill in your real values.
# cp .env.example .env

# PostgreSQL connection string (required — server exits immediately without it)
DATABASE_URL=postgres://user:password@localhost:5432/prana

# Set to "true" if your Postgres host requires SSL (most hosted providers do:
# Railway, Supabase, Render, Neon, RDS, etc.)
PGSSL=false

# Port the backend listens on (optional, defaults to 3001)
PORT=3001

# Anthropic API key — only needed for GET /api/advice (natural-language
# recommendations). Get one at https://console.anthropic.com/
# Without this, everything else (recommendations, rule checks, dashboard)
# still works fine — /api/advice will just return an error telling you
# this is missing.
ANTHROPIC_API_KEY=sk-ant-...

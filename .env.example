# Copy this file to .env and fill in your real Postgres connection string.
# Load it with a tool like `dotenv` or your host's env-var settings —
# server.js reads process.env.DATABASE_URL directly.

# Local Postgres example:
DATABASE_URL=postgres://postgres:password@localhost:5432/prana

# Hosted Postgres (Railway/Supabase/RDS/Render) usually needs SSL:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSL=true

PORT=3001
